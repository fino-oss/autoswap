# ─── AutoSwap API — Environment Variables ────────────────────────────────────
# Copy to .env for local dev, set as Railway env vars for production.

# Required: Admin secret to generate API keys via POST /admin/keys
ADMIN_SECRET=change-me-to-a-strong-secret

# Optional: Pre-loaded API keys (comma-separated, for persistence across restarts)
# Generate with: python -c "import secrets; print('ask-' + secrets.token_urlsafe(24))"
API_KEYS=ask-example-key-1,ask-example-key-2

# Optional: Agent wallet private key (for commission forwarding on-chain)
# This wallet sends collected commissions to COMMISSION_WALLET
# NEVER commit this value to git.
AGENT_WALLET_KEY=0xYOUR_AGENT_WALLET_PRIVATE_KEY_HERE

# Optional: Override commission destination wallet
# Default: 0x804dd2cE4aA3296831c880139040e4326df13c6e
# COMMISSION_WALLET=0x804dd2cE4aA3296831c880139040e4326df13c6e

# Server port (Railway sets this automatically)
PORT=8080
